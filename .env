# .env.development
REACT_APP_API_URL=http://localhost:3001
REACT_APP_BACKEND_ENABLED=true

# .env.production
REACT_APP_API_URL=https://your-domain.com
REACT_APP_BACKEND_ENABLED=true

# .env.fallback (for testing without backend)
REACT_APP_BACKEND_ENABLED=false

# Add these 4 lines to your existing .env file
REACT_APP_SAMPLE_REPO_URL=https://github.com/mohammed-ibenayad/full-requirment-tracebility
REACT_APP_SAMPLE_BRANCH=main
REACT_APP_SAMPLE_WORKFLOW_ID=quality-tracker-tests.yml
REACT_APP_SAMPLE_GITHUB_TOKEN=